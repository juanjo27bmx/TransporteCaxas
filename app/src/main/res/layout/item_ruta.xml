<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgIconoRuta"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_combi_outline"
            app:tint="#1A73E8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:layout_toStartOf="@id/tvPrecio"
            android:layout_toEndOf="@id/imgIconoRuta"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreRuta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Línea 10"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTrayecto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Baños del Inca → Centro"
                android:textColor="#5F6368"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servicio de transporte"
                android:textColor="#1A73E8"
                android:textSize="11sp"
                android:textStyle="italic" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPrecio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/fondo_input"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="S/ 1.50"
            android:textColor="#333333"
            android:textSize="12sp"
            android:textStyle="bold" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>